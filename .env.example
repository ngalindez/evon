# Evon — environment variables. Copy to .env and fill in. NEVER commit real secrets.
# Validated by src/infra/config/env.ts (Zod).

# --- Database (Neon Postgres) ---------------------------------------------------------------
# Pooled connection for queries. Locally, the docker-compose Postgres:
DATABASE_URL="postgresql://evon:evon@localhost:5432/evon?schema=public"
# Direct connection for migrations (Neon gives a separate non-pooled URL; same as above locally).
DIRECT_URL="postgresql://evon:evon@localhost:5432/evon?schema=public"

# --- Credential encryption ------------------------------------------------------------------
# 32-byte key, base64-encoded, for AES-256-GCM encryption of cloud credentials at rest.
# Generate one with:  openssl rand -base64 32
ENCRYPTION_KEY=""

# --- Auth.js --------------------------------------------------------------------------------
# Session signing secret. Generate with:  openssl rand -base64 32
AUTH_SECRET=""

# --- Cron -----------------------------------------------------------------------------------
# Shared secret the Vercel Cron request must carry (Authorization: Bearer <CRON_SECRET>).
# Vercel automatically attaches this header to cron invocations when CRON_SECRET is set.
CRON_SECRET=""

# --- Email (Resend) -------------------------------------------------------------------------
RESEND_API_KEY=""
EMAIL_FROM="Evon <noreply@example.com>"

# --- File storage (Cloudflare R2, S3-compatible) --------------------------------------------
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""

# --- Shelly cloud ---------------------------------------------------------------------------
# TODO(evon): exact base URL / auth shape unconfirmed — see CLAUDE.md "Shelly API shape".
SHELLY_API_BASE=""
